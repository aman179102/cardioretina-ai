# CardioRetina-AI Environment Configuration
# Copy this file to .env and adjust values as needed.

# Model checkpoint path (leave empty to use pretrained backbone)
MODEL_CHECKPOINT=
MODEL_CONFIG=

# Device: auto | cpu | cuda | cuda:0
DEVICE=auto

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=*

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Environment: development | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
